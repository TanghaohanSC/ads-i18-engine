# ==== Core ====
APP_ENV=dev
APP_NAME=ad-localization
LOG_LEVEL=INFO

# ==== Database (reuses local pg18 zip install) ====
DATABASE_URL=postgresql+psycopg://postgres:dev123@localhost:5432/ad_localization
DATABASE_URL_SYNC=postgresql+psycopg://postgres:dev123@localhost:5432/ad_localization

# ==== Auth / JWT ====
JWT_SECRET=change-me-to-random-64-bytes
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=14

# ==== Storage ====
STORAGE_DRIVER=local        # local | s3
STORAGE_LOCAL_ROOT=./storage
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT_URL=

# ==== AI providers (Phase 3) ====
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GOOGLE_PROJECT_ID=
VERTEX_LOCATION=us-central1

# ==== Frontend ====
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
